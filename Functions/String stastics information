#string stastics 

def string_stats():
    text = "Python3 is Awesome!"

    print("Characters:", len(text))

    digits = 0
    letters = 0
    spaces = 0
    special = 0
    vowels = 0
    consonants = 0

    for ch in text:
        if ch.isdigit():
            digits+=1
        elif ch.isalpha():
             letters+=1
             if ch in "aeiou":
                 vowels+=1
             else:
                 consonants+=1
        elif ch==" " :
            spaces+=1
        else:
            special+=1    
    print("letters=",letters)
    print("digits=",digits)
    print("spaces=",spaces)
    print("special=",special)
    print("vowels=",vowels)
    print("consonants=",consonants)

string_stats()
