#ATM simulator 
try:
    balance = 5000
    amount = int(input("Enter amount = "))

    if amount <= 0:
        raise ValueError("Amount must be greater than 0.")

    if amount > balance:
        raise ValueError("Insufficient balance.")

except ValueError as e:
    print(e)

else:
    balance -= amount
    print("Remaining Balance =", balance)

finally:
    print("Thank You for Visiting")
